# Copy to .env (docker compose reads it automatically) and set a real password.
AUTH_USER=admin
AUTH_PASS=change-me-to-a-strong-password

# Web UI port (default 3000).
WEB_PORT=3000

# Where to persist data on the host (cameras.json, go2rtc.yaml, session.secret).
# Defaults to ./data next to docker-compose.yml. Set an absolute path to store it elsewhere.
# DATA_PATH=./data

# Optional:
# SESSION_DAYS=30
# LOCKOUT_ATTEMPTS=5
# LOCKOUT_MINUTES=15
# TRUST_PROXY=1
