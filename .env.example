# Copy to .env (docker compose reads it automatically) and set a real password.
AUTH_USER=admin
AUTH_PASS=change-me-to-a-strong-password

# Web UI port (default 3000).
WEB_PORT=3000

# Where to persist data on the host (cameras.json, go2rtc.yaml, session.secret).
# Defaults to ./data next to docker-compose.yml. Set an absolute path to store it elsewhere.
# DATA_PATH=./data

# Enable low-latency WebRTC for REMOTE viewing. Without this, remote (proxied) clients use
# MSE (~1s); LAN clients already get WebRTC. Requires forwarding :8555 (TCP+UDP) to this host.
# Value = the address go2rtc advertises: a hostname/IP with port, or "stun:8555" to auto-detect.
# WEBRTC_CANDIDATE=cam.example.com:8555

# Optional:
# SESSION_DAYS=30
# LOCKOUT_ATTEMPTS=5
# LOCKOUT_MINUTES=15
# TRUST_PROXY=1
